# configuración de la base de datos Turso
# solo aplica para la versión live
# en desarrollo se asume que se está usando el contenedor de Docker
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# opcional: coma-separado para extra origins de confianza
BETTER_AUTH_TRUSTED_ORIGINS=

# OAuth Providers
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=